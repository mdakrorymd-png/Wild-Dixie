# ---- Application ----
ENVIRONMENT=development
PROJECT_NAME="Egypt Vacation Rentals API"

# ---- Database (PostgreSQL, async driver) ----
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/egypt_rentals

# ---- Security / JWT ----
# Generate a strong key, e.g. (PowerShell):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- OTP (phone verification) ----
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ---- SMS gateway ----
# console  -> prints the OTP to the server log (development only)
# (real providers like Vodafone/Twilio/SMSMisr are added in app/services/sms.py)
SMS_PROVIDER=console

# ---- Airbnb scraper ----
SCRAPER_MAX_ATTEMPTS=3
# Optional proxy to bypass Airbnb IP blocks (residential proxy recommended):
#   http://user:pass@gate.provider.com:7000
SCRAPER_PROXY=

# ---- iCal calendar sync ----
ENABLE_ICAL_SCHEDULER=true
ICAL_SYNC_INTERVAL_MINUTES=15
ICAL_FETCH_TIMEOUT_SECONDS=20
# Base URL used to build the public iCal export link given to Airbnb
PUBLIC_BASE_URL=http://localhost:8000
